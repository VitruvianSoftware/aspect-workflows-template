# User-specific settings file for this repo. May contain secrets such as API tokens.
.env

# Symlinks created by Bazel into the output tree
/bazel-*

# User-specific Bazel config — may hold remote-build (RBE) API keys.
# Loaded via `try-import %workspace%/user.bazelrc` from .bazelrc.
user.bazelrc

{{ if .Computed.javascript }}
node_modules/
{{ end }}
{{ if .Computed.python }}
*.venv/
{{ end }}
{{ if .Computed.ruby}}
vendor/bundle/
{{ end }}